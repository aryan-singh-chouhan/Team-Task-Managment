PORT=5000

DB_HOST=your_db_host
DB_PORT=4000
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
DB_SSL=true
JWT_SECRET=your_super_secret_key_minimum_32_characters
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Comma-separated frontend origins allowed to call the API.
# Example for Railway: CLIENT_URL=https://your-frontend.railway.app,https://your-custom-domain.com
# Use COOKIE_SAME_SITE=none when the frontend is on a different site than the API.
COOKIE_SAME_SITE=lax